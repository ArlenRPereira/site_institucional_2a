        "replyTo": "={{ $json.data.email }}",
        "subject": "=Novo contato do site — {{ $json.data.nome }} ({{ $json.data.interesse }})",
        "emailFormat": "html",
        "html": "=<h2>Novo contato recebido pelo site</h2>\n<p><strong>Nome:</strong> {{ $json.data.nome }}</p>\n<p><strong>Email:</strong> {{ $json.data.email }}</p>\n<p><strong>Telefone:</strong> {{ $json.data.telefone }}</p>\n<p><strong>Empresa:</strong> {{ $json.data.empresa }}</p>\n<p><strong>Interesse:</strong> {{ $json.data.interesse }}</p>\n<p><strong>Mensagem:</strong><br>{{ $json.data.mensagem }}</p>",
        "options": {}
      },
      "id": "a1b2c3d4-0000-4000-8000-000000000008",
      "name": "Enviar Email",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 2.1,
      "position": [1660, -60],
