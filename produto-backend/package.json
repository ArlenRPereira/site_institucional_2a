{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.27.0",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:debug": "tsx watch --inspect src/index.ts",
    "build": "tsc --outDir dist",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "db:types": "supabase gen types typescript --local > .claude/types/database.ts",
    "swagger:validate": "npx @redocly/cli lint openapi.yaml",
    "docker:build": "docker build -t backend .",
    "docker:up": "docker compose up -d"
  },
  "dependencies": {
    "@org/shared-contracts": "workspace:*",
    "@supabase/supabase-js": "^2.0.0",
    "express": "^4.18.0",
    "zod": "^3.23.0",
    "pino": "^9.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.0",
    "@faker-js/faker": "^9.0.0",
    "typescript": "~5.7.0",
    "tsx": "^4.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "supertest": "^7.0.0"
  }
}
