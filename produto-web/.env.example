# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# n8n — webhook do formulário de contato (server-only, nunca NEXT_PUBLIC_)
N8N_CONTACT_WEBHOOK_URL=
N8N_CONTACT_WEBHOOK_TOKEN=

# Porta do servidor Next.js standalone (deploy Docker/EasyPanel).
# O EasyPanel injeta PORT=80 por padrão, sobrescrevendo o do Dockerfile —
# definir explicitamente como 3000 no Environment de produção (ver README.md).
PORT=3000
