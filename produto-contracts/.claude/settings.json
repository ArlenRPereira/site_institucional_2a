{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "model": "claude-sonnet-4-6",

  "permissions": {
    "allow": [
      "Read",

      "Bash(pnpm build)",
      "Bash(pnpm watch)",
      "Bash(pnpm typecheck)",
      "Bash(pnpm version *)",
      "Bash(pnpm install)",
      "Bash(pnpm add zod*)",

      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git fetch *)",
      "Bash(git tag *)",

      "Bash(ls *)",
      "Bash(find *)",
      "Bash(grep *)"
    ],

    "ask": [
      "Bash(git push *)",
      "Bash(pnpm publish)",
      "Bash(npm publish *)"
    ],

    "deny": [
      "Bash(rm -rf *)",
      "Bash(pnpm add *)",
      "Read(.env)",
      "Read(.env.*)",
      "Write(.env)",
      "Write(.env.*)"
    ]
  },

  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "pnpm typecheck 2>&1 | tail -5"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "echo '\\a'"
          }
        ]
      }
    ]
  },

  "env": {
    "NODE_ENV": "development"
  }
}
