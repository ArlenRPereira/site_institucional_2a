          "combinator": "and"
        },
        "options": {}
      },
      "id": "a1b2c3d4-0000-4000-8000-000000000005",
      "name": "Captcha Válido?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [940, 180]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const body = $input.item.json.body || {};\n\nfunction limparQuebrasDeLinha(valor) {\n  return String(valor || '').replace(/[\\r\\n]+/g, ' ').trim();\n}\n\nfunction escapeHtml(valor) {\n  return String(valor || '')\n    .replace(/&/g, '&amp;')\n    .replace(/</g, '&lt;')\n    .replace(/>/g, '&gt;')\n    .replace(/\"/g, '&quot;');\n}\n\nconst nome = limparQuebrasDeLinha(body.nome).slice(0, 200);\nconst email = limparQuebrasDeLinha(body.email).slice(0, 200);\nconst telefone = limparQuebrasDeLinha(body.telefone).slice(0, 50);\nconst empresa = limparQuebrasDeLinha(body.empresa).slice(0, 200);\nconst interesse = limparQuebrasDeLinha(body.interesse);\nconst mensagem = String(body.mensagem || '').slice(0, 5000);\n\nconst errors = [];\n\nif (!nome) errors.push('Nome é obrigatório.');\n\nconst emailRegex = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/;\nif (!email || !emailRegex.test(email)) errors.push('Email inválido.');\n\nif (!mensagem || mensagem.trim().length < 5) errors.push('Mensagem é obrigatória.');\n\nconst interesseOptions = ['Tecnologia, SaaS e IA', 'ESG e Projetos Sociais', 'Ambos', 'Outro'];\nif (!interesseOptions.includes(interesse)) errors.push('Interesse inválido.');\n\nreturn {\n  valid: errors.length === 0,\n  errors,\n  data: {\n    nome: escapeHtml(nome),\n    email: escapeHtml(email),\n    telefone: escapeHtml(telefone),\n    empresa: escapeHtml(empresa),\n    interesse: escapeHtml(interesse),\n    mensagem: escapeHtml(mensagem).replace(/\\n/g, '<br>')\n  }\n};"
      },
      "id": "a1b2c3d4-0000-4000-8000-000000000006",
      "name": "Validar e Sanitizar Campos",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
