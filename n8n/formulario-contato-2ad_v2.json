        },
        "options": {}
      },
      "id": "a1b2c3d4-0000-4000-8000-000000000003",
      "name": "Honeypot Vazio? (humano)",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [460, 300]
